# ════════════════════════════════════════════════════════════════
# PROJETO ATLÂNTICO — Variáveis de Ambiente
# ATENÇÃO: Copie para .env e NUNCA comite .env no repositório.
# Material de chave NUNCA deve ser exposto em variáveis de ambiente.
# Use Docker Secrets ou HSM para produção.
# ════════════════════════════════════════════════════════════════

# ─── Ambiente ────────────────────────────────────────────────────
ATLANTICO_ENV=development
# Valores: development | staging | production

# ─── Criptografia Pós-Quântica ────────────────────────────────────
# IMPORTANTE: Alterar estas variáveis aciona a cripto-agilidade.
# Dados existentes continuam usando o algoritmo registrado no envelope.
# Novos dados usarão o algoritmo configurado aqui.
ATLANTICO_KEM_SUITE=hybrid-kyber768-x25519
# Opções: hybrid-kyber768-x25519 | hybrid-kyber1024-x25519 | pqc-mlkem768 | classical-x25519

ATLANTICO_SIG_SUITE=hybrid-dilithium3-ed25519
# Opções: hybrid-dilithium3-ed25519 | hybrid-dilithium5-ed25519 | pqc-mldsa65 | classical-ed25519

# Ativar suite clássica requer confirmação explícita (proteção contra downgrade acidental)
ATLANTICO_ALLOW_CLASSICAL_FALLBACK=false

# ─── Chave Mestra de Criptografia (KEK) ──────────────────────────
# Em produção: injete via Docker Secret ou HSM, não via env var.
# Formato: hex-encoded de 32 bytes (256 bits)
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
ATLANTICO_MASTER_KEY_HEX=SUBSTITUA_POR_32_BYTES_HEX_ALEATORIOS

# ─── Banco de Dados ───────────────────────────────────────────────
ATLANTICO_DB_HOST=localhost
ATLANTICO_DB_PORT=5432
ATLANTICO_DB_NAME=atlantico
ATLANTICO_DB_USER=atlantico_app
ATLANTICO_DB_PASSWORD=SUBSTITUA_POR_SENHA_FORTE
ATLANTICO_DB_POOL_SIZE=10
ATLANTICO_DB_MAX_OVERFLOW=20

# ─── Redis ────────────────────────────────────────────────────────
ATLANTICO_REDIS_URL=redis://localhost:6379/0

# ─── API ──────────────────────────────────────────────────────────
ATLANTICO_API_HOST=0.0.0.0
ATLANTICO_API_PORT=8000
ATLANTICO_API_WORKERS=4

# JWT
ATLANTICO_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
ATLANTICO_JWT_REFRESH_TOKEN_EXPIRE_HOURS=8

# ─── Credenciais de Fontes OSINT ─────────────────────────────────
# ATENÇÃO: Em produção, use KeyManager para armazenar credenciais criptografadas.
# Estas são apenas para configuração inicial de desenvolvimento.

# INPE / TerraMA2
ATLANTICO_INPE_API_KEY=

# ESA Copernicus Data Space (OAuth2)
ATLANTICO_ESA_CLIENT_ID=
ATLANTICO_ESA_CLIENT_SECRET=

# Portal da Transparência (CGU)
ATLANTICO_TRANSPARENCIA_API_KEY=

# ─── Observabilidade ──────────────────────────────────────────────
ATLANTICO_LOG_LEVEL=INFO
# Valores: DEBUG | INFO | WARNING | ERROR | CRITICAL

ATLANTICO_OTEL_ENDPOINT=http://localhost:4317
ATLANTICO_METRICS_PORT=9090

# ─── Rotação de Chaves ────────────────────────────────────────────
# Intervalo máximo em dias antes de rotação obrigatória
ATLANTICO_KEY_ROTATION_INTERVAL_DAYS=90
ATLANTICO_KEY_RETIREMENT_GRACE_PERIOD_DAYS=30
