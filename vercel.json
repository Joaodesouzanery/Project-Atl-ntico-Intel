{
  "version": 2,
  "builds": [
    {
      "src": "api/*.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "50mb" }
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/health",  "dest": "/api/health.py" },
    { "src": "/api/analyze", "dest": "/api/analyze.py" },
    { "src": "/api/network", "dest": "/api/network.py" },
    { "src": "/api/risk",    "dest": "/api/risk.py" },
    { "src": "/api/demo",    "dest": "/api/demo.py" },
    { "src": "/",            "dest": "/public/index.html" },
    { "src": "/(.*)",        "dest": "/public/$1" }
  ]
}
