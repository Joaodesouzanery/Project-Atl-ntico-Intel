{
  "version": 2,
  "builds": [
    {
      "src": "api/*.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "50mb" }
    }
  ],
  "routes": [
    { "src": "/api/health",  "dest": "/api/health.py" },
    { "src": "/api/analyze", "dest": "/api/analyze.py" },
    { "src": "/api/network", "dest": "/api/network.py" },
    { "src": "/api/risk",    "dest": "/api/risk.py" },
    { "src": "/api/demo",        "dest": "/api/demo.py" },
    { "src": "/api/sigint_demo", "dest": "/api/sigint_demo.py" },
    { "src": "/api/atlas_demo",  "dest": "/api/atlas_demo.py" },
    { "src": "/(.*)",            "dest": "/api/index.py" }
  ]
}
